FROM ubuntu:latest
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
  ca-certificates curl \
  python3 python3-venv python3-pip \
  ffmpeg \
  build-essential \
  && rm -rf /var/lib/apt/lists/*

# Node.js 22 LTS
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
  && apt-get update && apt-get install -y nodejs \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python venv (avoids PEP 668)
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy package manifests first for layer caching
COPY bot/package*.json ./

RUN npm ci --omit=dev

COPY bot/ ./

# Only 'requests' is needed — WHISPER_ENDPOINT routes transcription to the
# whisper container, so openai-whisper (and PyTorch, ~2 GB) are never used here.
# For local dev without Docker, install the full requirements.txt instead.
RUN pip install --no-cache-dir requests

CMD ["node", "src/bot.js"]

# ── Required ─────────────────────────────────────────────────────────────────
# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-discord-bot-token-here

# ── Whisper (speech-to-text) ─────────────────────────────────────────────────
# Model size: tiny | base | small | medium | large
# Larger models are more accurate but slower and use more RAM.
WHISPER_MODEL=base

# When using the containerised Whisper service (recommended), this is set
# automatically by docker-compose. Override only when running the bot locally
# without Docker.
# WHISPER_ENDPOINT=http://whisper:9000/v1/audio/transcriptions

# ── Ollama (LLM) ─────────────────────────────────────────────────────────────
# Model tag to use. Must already be pulled inside the ollama container.
OLLAMA_MODEL=qwen2.5:0.5b-instruct

# Endpoint set automatically by docker-compose. Override for external Ollama.
# OLLAMA_ENDPOINT=http://ollama:11434/v1/chat/completions

OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
# Keep this low for snappy TTS responses (sweet spot: 60-100 tokens).
OLLAMA_MAX_TOKENS=80

# ── GLaDOS voice (TTS) ───────────────────────────────────────────────────────
# Endpoint set automatically by docker-compose.
# TTS_ENDPOINT=http://glados_voice:5050/v1/audio/speech
TTS_VOICE=glados

# ── Conversation ─────────────────────────────────────────────────────────────
# Approximate character budget for per-session conversation history.
# Older messages are dropped (LIFO) when this limit is reached.
MAX_CONVERSATION_CHARS=6000

# ── GLaDOS personality ───────────────────────────────────────────────────────
# Override the system prompt to customise personality or add constraints.
# Leave blank to use the built-in GLaDOS prompt.
GLADOS_SYSTEM_PROMPT=
